@model ProductQueryModel

@{
    ViewData["Title"] = "All Jewelry - Admin";
}

<h1>All Jewelry</h1>

<div class="container">
    @if (Model.Products.Count() > 0)
    {
        <table>
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Products)
                {
                    <tr>
                        <td>
                            <img src="@item.ImagePath" alt="@item.Name" class="product-image" />
                            @item.Name
                        </td>
                        <td>@item.Price.ToString("C")</td>
                        <td>
                            <div class="card-body">
                                @if (item.IsForSale == true)
                                {
                                    <form asp-action="Delete" asp-controller="Admin" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="productType" value="@item.ProductType" />
                                        <button type="submit" class="btn btn-danger">Delete</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No jewelry found.</p>
    }

    <div class="row mt-3">
        <div class="col-md-12">
            <partial name="_PaginationPartial" model="@Model" />
        </div>
    </div>
</div>

<style>
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th,
    td {
        border: 1px solid #ddd;
        padding: 8px;
        text-align: left;
    }

    th {
        background-color: #f2f2f2;
    }

    .product-image {
        max-width: 100px;
        max-height: 100px;
    }

    .card-body {
        text-align: center;
    }

    .btn {
        margin-right: 10px;
    }
</style>